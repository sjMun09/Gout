# ============================================================================
# Gout — 루트 .env.example
# 사용법: cp .env.example .env  후 값 수정.
# docker-compose.yml 이 이 파일의 변수를 주입한다.
# ============================================================================

# ----- DB 자격증명 -----
# docker-compose.yml 이 이 값을 POSTGRES_* 와 DB_* 양쪽에 주입.
# dev 환경이라도 팀 외부 공유 서버라면 반드시 변경할 것.
POSTGRES_DB=gout_dev
POSTGRES_USER=gout
POSTGRES_PASSWORD=gout1234

# ----- JWT -----
# HS256 서명용 시크릿. 최소 32자(256bit) 이상.
# 임시값 생성: openssl rand -base64 48
JWT_SECRET=dev-secret-change-me-in-prod-at-least-32-chars-long

# ----- 프론트엔드 (빌드 타임 주입) -----
# 카카오맵 JavaScript 키. 비워두면 placeholder 로 빌드되고
# /hospital 페이지에서 지도는 뜨지 않지만 앱 자체는 동작.
NEXT_PUBLIC_KAKAO_MAP_KEY=

# ----- LLM / 외부 API (논문 크롤러 등, 현재 미사용이면 공란) -----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# 논문 크롤러 on/off (true/false). 기본 false.
PAPER_CRAWLER_ENABLED=false
