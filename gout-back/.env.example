# ============================================================================
# Gout Backend — .env.example
# 로컬에서 ./gradlew bootRun 으로 직접 실행할 때 사용.
# docker compose 경로로 실행할 때는 루트 .env 만 있으면 된다.
# ============================================================================

# ----- DataSource -----
# 로컬 단독 실행 시 postgres 호스트가 localhost.
# docker 네트워크 내부에서는 postgres 서비스명 사용: jdbc:postgresql://postgres:5432/gout_dev
DB_URL=jdbc:postgresql://localhost:5432/gout_dev
DB_USERNAME=gout
DB_PASSWORD=gout1234

# ----- JWT -----
JWT_SECRET=dev-secret-change-me-in-prod-at-least-32-chars-long

# ----- Spring Profile -----
SPRING_PROFILES_ACTIVE=dev
