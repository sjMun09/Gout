# ============================================================================
# Gout Backend — .env.example
# 로컬에서 ./gradlew bootRun 으로 직접 실행할 때 사용.
# docker compose 경로로 실행할 때는 루트 .env 만 있으면 된다.
# ============================================================================

# ----- DataSource -----
# 로컬 단독 실행 시 postgres 호스트가 localhost.
# docker 네트워크 내부에서는 postgres 서비스명 사용: jdbc:postgresql://postgres:5432/gout_dev
DB_URL=jdbc:postgresql://localhost:5432/gout_dev
DB_USERNAME=gout
DB_PASSWORD=gout1234

# ----- JWT -----
JWT_SECRET=dev-secret-change-me-in-prod-at-least-32-chars-long

# ----- Spring Profile -----
SPRING_PROFILES_ACTIVE=dev

# ----- CORS / Uploads -----
# prod 프로파일에서는 CORS_ALLOWED_ORIGINS 가 필수이며 와일드카드(*)는 금지.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3010
UPLOADS_BASE_DIR=./uploads

# ----- Kakao -----
# 서버 전용 키. 프론트 public env 에 넣지 말 것.
KAKAO_REST_API_KEY=
KAKAO_ADMIN_KEY=
KAKAO_NATIVE_APP_KEY=

# ----- LLM / Crawler -----
# prod 에서 PAPER_CRAWLER_ENABLED=true 이면 두 키 모두 필수.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PAPER_CRAWLER_ENABLED=false
