# ============================================================================
# Gout Frontend — .env.example
# npm run dev 로 직접 실행할 때 사용.
# docker compose 경로에서는 build-arg 로 주입되므로 별도 설정 불필요.
# ============================================================================

# 백엔드 API 기본 URL (브라우저에서 접근하므로 localhost 로 고정)
NEXT_PUBLIC_API_URL=http://localhost:8080

# 카카오맵 JavaScript 키. 비워두면 /hospital 페이지 지도만 비활성, 앱은 동작.
NEXT_PUBLIC_KAKAO_MAP_KEY=
